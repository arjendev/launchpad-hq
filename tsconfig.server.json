{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"]
  },
  "include": ["src/server/**/*.ts", "src/shared/**/*.ts"],
  "exclude": ["src/server/**/__tests__/**", "src/server/**/*.test.ts", "src/server/**/*.spec.ts", "src/shared/**/__tests__/**", "src/shared/**/*.test.ts"]
}
