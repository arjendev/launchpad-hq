{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/server",
    "rootDir": "./src/server",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"]
  },
  "include": ["src/server/**/*.ts"],
  "exclude": ["src/server/**/__tests__/**", "src/server/**/*.test.ts", "src/server/**/*.spec.ts"]
}
