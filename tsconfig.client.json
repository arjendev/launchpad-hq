{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/client",
    "rootDir": "./src/client",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"]
  },
  "include": ["src/client/**/*.ts", "src/client/**/*.tsx"],
  "exclude": ["src/client/**/__tests__/**", "src/client/**/*.test.ts", "src/client/**/*.test.tsx", "src/client/**/*.spec.ts", "src/client/**/*.spec.tsx"]
}
