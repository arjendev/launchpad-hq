{
  "name": "launchpad-hq",
  "version": "0.1.0",
  "description": "A command and control center for managing multiple projects across repositories",
  "type": "module",
  "bin": {
    "launchpad-hq": "./dist/cli.js"
  },
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"vite\"",
    "dev:server": "tsx watch --ignore 'node_modules' --ignore 'dist' --ignore '.squad' --ignore 'src/client' src/server/index.ts",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "vite build",
    "start": "node dist/server/index.js",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:server": "vitest run --project server",
    "test:client": "vitest run --project client",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.client.json"
  },
  "keywords": [
    "launchpad",
    "devcontainer",
    "copilot",
    "dashboard",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.1.0",
    "@mantine/core": "^7.17.3",
    "@mantine/hooks": "^7.17.3",
    "@tabler/icons-react": "^3.40.0",
    "@tanstack/react-query": "^5.76.2",
    "@tanstack/react-router": "^1.121.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.1.0",
    "graphql": "^16.13.1",
    "graphql-request": "^7.4.0",
    "postcss": "^8.5.8",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.4",
    "eslint": "^9.27.0",
    "happy-dom": "^20.8.4",
    "jsdom": "^28.1.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.0"
  }
}
