{
  "name": "launchpad-hq",
  "version": "0.1.4",
  "description": "A command and control center for managing multiple projects across repositories",
  "type": "module",
  "bin": {
    "launchpad-hq": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "scripts/"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "//postinstall": "Patches vscode-jsonrpc exports map and copilot-sdk bare imports for ESM compat",
    "postinstall": "node scripts/patch-sdk.js",
    "//prepare": "Runs build when installing from GitHub source; skipped in CI",
    "prepare": "node -e \"if(!process.env.CI){require('child_process').execSync('npm run build',{stdio:'inherit'})}\"",
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"vite\"",
    "dev:server": "tsx watch --ignore 'node_modules' --ignore 'dist' --ignore '.squad' --ignore 'src/client' src/server/index.ts",
    "dev:daemon": "tsx watch --ignore 'node_modules' --ignore 'dist' --ignore '.squad' --ignore 'src/client' --ignore 'src/server' src/daemon/index.ts",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p tsconfig.server.json && node -e \"require('fs').writeFileSync('dist/package.json','{\\\"type\\\":\\\"module\\\"}')\"",
    "build:client": "vite build",
    "start": "node dist/server/index.js",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:server": "vitest run --project server",
    "test:client": "vitest run --project client",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.client.json",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "launchpad",
    "devcontainer",
    "copilot",
    "dashboard",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/arjendev/launchpad-hq.git"
  },
  "homepage": "https://github.com/arjendev/launchpad-hq",
  "bugs": {
    "url": "https://github.com/arjendev/launchpad-hq/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/static": "^9.0.0",
    "@github/copilot-sdk": "^0.1.32",
    "@mantine/core": "^7.17.3",
    "@mantine/hooks": "^7.17.3",
    "@mantine/notifications": "^8.3.18",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@tabler/icons-react": "^3.40.0",
    "@tanstack/react-query": "^5.76.2",
    "@tanstack/react-router": "^1.121.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.1.0",
    "graphql": "^16.13.1",
    "graphql-request": "^7.4.0",
    "node-pty": "^1.1.0",
    "postcss": "^8.5.8",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "vscode-jsonrpc": "^8.2.1",
    "ws": "^8.18.2"
  },
  "overrides": {
    "esbuild": "^0.25.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.21",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.4",
    "eslint": "^9.27.0",
    "happy-dom": "^20.8.4",
    "jsdom": "^28.1.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.0"
  }
}
