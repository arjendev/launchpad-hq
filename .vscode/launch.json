{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Server (Launch)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/tsx",
      "args": ["${workspaceFolder}/src/server/index.ts"],
      "env": { "LAUNCHPAD_SELF_DAEMON": "true" },
      "restart": true,
      "skipFiles": ["<node_internals>/**"],
      "console": "integratedTerminal"
    },
    {
      "name": "Client (Launch)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src/client",
      "sourceMaps": true,
      "preLaunchTask": "dev:client"
    },
    {
      "name": "Docs (VitePress)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/vitepress",
      "args": ["dev", "docs"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": ["Server (Launch)", "Client (Launch)"],
      "stopAll": true
    }
  ]
}
