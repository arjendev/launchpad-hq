{
  "name": "launchpad",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:22",
  "remoteUser": "node",
  "containerUser": "node",
  "runArgs": ["--network=launchpad-net", "--network-alias=launchpad-hq"],
  "initializeCommand": "docker network inspect launchpad-net >/dev/null 2>&1 || docker network create launchpad-net",
  "mounts": [
    "source=copilot-cli-data,target=/home/node/.copilot,type=volume"
  ],
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1.1.0": {},
    "ghcr.io/devcontainers/features/copilot-cli:1.0.0": {},
    "ghcr.io/stuartleeks/dev-container-features/dev-tunnels:0.0.1": {},
    "ghcr.io/devcontainers/features/docker-in-docker": { "moby": false }
  },
  "postCreateCommand": "sudo chown -R node:node /home/node/.copilot && npm install && npx playwright install chromium --with-deps",
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat"
      ]
    }
  }
}
